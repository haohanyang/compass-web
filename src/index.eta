<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="<%= it.csrfToken %>" />
    <meta name="base-route" content="<%= it.baseRoute %>" />
    <base href="/<%= it.baseRoute ? it.baseRoute + '/' : '' %>" />
    <title><%= it.appName %></title>
    <link rel="icon" href="favicon.svg" type="image/svg+xml" />
    <link
      href="https://fonts.cdnfonts.com/css/euclid-circular-a"
      rel="stylesheet"
    />
    <style>
      body {
        margin: 0;
      }

      #sandbox-app {
        width: 100vw;
        height: 100vh;
      }

      .compass-init-loader {
        margin-left: auto;
        margin-right: auto;
        margin-top: 10vh;
      }

      .loader-before-app-loads {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        margin-top: 10vh;
      }

      .loader-before-app-loads-spinner {
        width: 24px;
        height: 24px;
        border: 2px solid transparent;
        border-top-color: #1c2d38;
        border-radius: 50%;
        box-sizing: border-box;
        animation: rotation 700ms ease infinite;
      }

      .loader-before-app-loads-label {
        color: #00684a;
        font-family: 'Euclid Circular A', sans-serif;
        font-size: 18px;
        font-weight: 700;
      }

      @keyframes rotation {
        0% {
          transform: rotate(0deg);
        }

        100% {
          transform: rotate(360deg);
        }
      }
    </style>
  </head>

  <body>
    <div id="sandbox-app">
      <div class="loader-before-app-loads">
        <div class="loader-before-app-loads-spinner"></div>
        <span class="loader-before-app-loads-label">Loading Compass</span>
      </div>
    </div>
    <script src="compass.js"></script>
  </body>
</html>
